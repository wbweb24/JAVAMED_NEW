<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.javamed_new.SecondaryController">
    <top>
        <VBox fx:id="menuContainer" spacing="10" alignment="CENTER_LEFT">
            <Label text="Menú Principal" />
        </VBox>
    </top>
    <left>
        <VBox fx:id="subMenuContainer" spacing="10" alignment="CENTER_LEFT">
            <Label text="Opciones" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="workAreaContainer">
            <Label text="Área de Trabajo" />
        </StackPane>
    </center>
    <bottom>
        <VBox alignment="CENTER">
            <Button fx:id="secondaryButton" text="Cerrar Sesión" onAction="#switchToPrimary" />
        </VBox>
    </bottom>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</BorderPane>
